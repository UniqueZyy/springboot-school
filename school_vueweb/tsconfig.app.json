{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "env.d.ts",
    "src/App.vue",
    "src/main.ts",
    "src/api/**/*",
    "src/assets/**/*",
    "src/router/**/*",
    "src/stores/**/*",
    "src/utils/**/*",
    "src/views/**/*"
  ],
  "exclude": ["src/**/__tests__/*", "src/views/components/UserProfile.vue"],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
